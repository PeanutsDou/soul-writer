{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Soul Writer",
  "version": "0.1.0",
  "identifier": "com.soulwriter.desktop",
  "build": {
    "frontendDist": "../dist/renderer",
    "devUrl": "http://localhost:5175",
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "windows": [
      {
        "title": "Soul Writer",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "resizable": true,
        "fullscreen": false,
        "backgroundColor": "#fbfbf9"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
