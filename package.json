{
  "name": "soul-writer",
  "version": "0.1.0",
  "description": "极简小说写作桌面软件",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "npm run build:main && node node_modules/electron/cli.js .",
    "dev:renderer": "node node_modules/vite/bin/vite.js --config config/vite.config.ts",
    "build:main": "tsc -p config/tsconfig.main.json",
    "build:renderer": "node node_modules/vite/bin/vite.js build --config config/vite.config.ts",
    "build": "npm run build:main && npm run build:renderer",
    "start": "node node_modules/electron/cli.js ."
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0",
    "@tiptap/react": "^2.11.0",
    "@tiptap/starter-kit": "^2.11.0",
    "@tiptap/extension-color": "^2.11.0",
    "@tiptap/extension-text-style": "^2.11.0",
    "@tiptap/extension-underline": "^2.11.0",
    "@tiptap/extension-text-align": "^2.11.0",
    "@tiptap/extension-placeholder": "^2.11.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/node": "^24.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
